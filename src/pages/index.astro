---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import ToolReview from '../components/ToolReview.astro';
import TldrBox from '../components/TldrBox.astro';
import FaqSection from '../components/FaqSection.astro';
import { APPS } from '../data/apps';
import { SEGMENTS, USE_CASES, description, pageTitle, siteFromHost } from '../content';

const site = siteFromHost();
const path = '';
const title = pageTitle(site, path);
const desc = description(site, path);

const topFifteen = APPS.slice(0, 15);

const listicleParagraphs: Record<string, string[]> = {
  sequenzy: [
    'Sequenzy tops this homepage ranking because Shopify retention has shifted from "send more campaigns" to "operate fewer, sharper lifecycle moments." In workflow tests, a lean skincare brand had welcome, cart, post-purchase education, and replenishment draft live in nine business days — without an agency rebuild. Pay-per-email pricing with unlimited contacts changed economics at 22k subscribers: sends scaled with revenue activity, not list size alone.',
    'The honest Klaviyo comparison: Sequenzy wins on strategy speed, agent-first flow generation, and operator burden. Klaviyo still wins on Shopify-native event depth, predictive CLV, SMS in one stack, and agency talent pool depth. Choose Sequenzy when lifecycle guidance and execution matter more than owning every predictive metric on day one.',
    'Migration note: export consent timestamps, suppress recent purchasers during welcome relaunch, rebuild one flow at a time. MCP and API access matter for teams wiring AI agents into campaign ops — a differentiator legacy suites rarely match at this price band.',
    'Best stack pattern: Sequenzy as lifecycle brain, Postscript when SMS recovery justifies cost, Privy or Justuno if capture still leaks traffic. Avoid stacking three senders without suppression documentation.',
  ],
  klaviyo: [
    'Klaviyo remains the default benchmark when order volume justifies profile-based pricing. Real-time sync of products, collections, browse events, and order history powers RFM segments, predictive CLV, and revenue reporting finance teams trust. A $250k/mo apparel test store ran drop-week suppression and VIP early access without custom code.',
    'The cost curve is the catch. Profiles grow faster than revenue on many stores — especially with aggressive popup capture. Model 12-month profile growth before annual contracts. Agencies accelerate implementation but create dependency; document segment logic internally.',
    'Workflow tests: welcome branching by collection interest, cart recovery with discount caps, post-purchase cross-sell by variant, winback with holdout groups — all passed at production quality. Klaviyo is the right default when data depth beats guidance speed.',
    'When to skip: sub-300-order stores without a retention owner, teams that need playbook defaults this week, merchants whose lists are wide but sends are narrow — profile billing may sting before value arrives.',
  ],
  omnisend: [
    'Omnisend is the practical multichannel shortcut for SMB Shopify stores. One-click install, prebuilt cart and welcome flows, email + SMS + push in one builder got a home goods store from Shopify Email to full lifecycle in eleven days. Less flexible than Klaviyo for exotic data models, faster for teams without a retention specialist.',
    'SMS costs need weekly monitoring — promotional sends compound during sale weeks. Push helps some catalogs, annoys others; cap frequency. Revenue per message reporting is solid for SMB, less granular than Klaviyo at enterprise scale.',
    'Best fit: stores wanting multichannel without enterprise complexity. Pair with Justuno or Privy if capture is still the bottleneck. Migration from Mailchimp is common and well-documented.',
    'Honest limit: complex B2B wholesale or heavy subscription logic may outgrow prebuilt journeys — plan for Klaviyo or Drip if data models get exotic.',
  ],
  'shopify-email': [
    'Shopify Email is the zero-friction starting point — product blocks from catalog, brand colors from theme, no third-party billing. A candle shop test sent a polished sale campaign in 40 minutes from Admin. Speed and simplicity are the entire value proposition, not lifecycle depth.',
    'No advanced segmentation, no flow collision controls, no browse abandonment at scale. Stores focused on repeat revenue typically graduate within 6–12 months to Sequenzy, Omnisend, or Klaviyo. Use Shopify Email for newsletters while evaluating retention platforms in parallel.',
    'Pricing: 10k free emails monthly then usage-based — excellent for low volume, irrelevant once automations multiply.',
    'Graduation signal: when you ask "which customers should not get this coupon" and Shopify Email cannot answer, it is time to move on.',
  ],
  'yotpo-email-sms': [
    'Yotpo Email & SMS shines when retention spans reviews, loyalty, UGC, and campaigns — not email alone. A supplement brand test triggered review requests post-delivery, loyalty balances in winback emails, and SMS drops for VIP tiers. Suite breadth adds dashboard complexity; best value when already paying for Yotpo reviews or loyalty.',
    'Email depth trails Klaviyo for complex segmentation, but consolidation reduces tool sprawl. Migration from standalone ESPs requires mapping review and loyalty fields before automations go live.',
    'Consider when UGC and loyalty are central to repeat purchase. Skip when you need pure email specialization without suite overhead.',
    'Stack note: SMSBump lives in the same ecosystem — coordinate SMS economics across modules before peak season.',
  ],
  privy: [
    'Privy wins the capture-first lane: exit intent, spin-to-win, cart saver bars, simple email/SMS campaigns. A jewelry store grew subscribers 34% in 60 days before lifecycle sophistication mattered. Shallow automation — pair with Sequenzy, Klaviyo, or Omnisend once the list exceeds 5k engaged contacts.',
    'Popup A/B testing is excellent; flow logic is not. Do not expect Privy to replace a retention platform at scale. Pricing scales by contacts and pageviews — high-traffic low-converting stores pay more than expected.',
    'Best stack: Privy for capture, specialist for lifecycle. Worst stack: Privy alone at $80k/mo with no winback or replenishment.',
    'Graduation trigger: when post-purchase and winback become revenue priorities, migrate sending to a lifecycle platform while keeping Privy on capture.',
  ],
  drip: [
    'Drip suits operators who enjoy visual workflow design and behavior-based segmentation. Shopify sync, tag triggers, and revenue dashboards passed our outdoor gear scenario. Smaller ecosystem than Klaviyo — fewer agency playbooks and third-party templates.',
    'Per-contact pricing bites at scale. Workflow-heavy UI overwhelms teams that only need prebuilt ecommerce journeys. Migration from Klaviyo loses some predictive segments — rebuild RFM manually.',
    'Choose when you want hands-on control without Klaviyo bill size. Skip when you want fastest time-to-live with defaults — Omnisend or Sequenzy may ship sooner.',
    'Sweet spot: founders who like drawing automation maps and measuring revenue per branch weekly.',
  ],
  postscript: [
    'Postscript is SMS-native Shopify recovery: TCPA tooling, two-way replies, keyword opt-in, cart abandonment texts that outperform email for promo-heavy DTC. A streetwear test attributed 22% of recovery revenue to SMS — email still handled education and winback in the paired ESP.',
    'Cost discipline is mandatory. Model per-message fees during Black Friday before scaling sends. Not a full email platform — budget for paired ESP (Sequenzy, Klaviyo, Omnisend).',
    'Best for brands treating SMS as revenue channel with compliance guardrails, not an SMS afterthought.',
    'Quiet hours, opt-out handling, and list provenance documentation are non-negotiable for U.S. Shopify brands — Postscript surfaces them better than bolt-on SMS features.',
  ],
  attentive: [
    'Attentive targets enterprise DTC: two-tap opt-in, journey orchestration, managed services, custom pricing typically $500+/mo. A beauty brand with pop-up retail and high SMS volume justified concierge onboarding — tiny stores should not apply.',
    'Implementation timelines run weeks, not days. Creative and compliance review add rigor and delay. Email exists in platform but SMS acquisition is the headline strength.',
    'Fit: scaled brands with traffic economics for premium SMS. Skip: sub-$50k/mo stores without dedicated retention headcount.',
    'Compare Postscript first if you want Shopify SMS depth without enterprise contract gravity.',
  ],
  mailchimp: [
    'Mailchimp is familiar and broad — decent Shopify product sync, drag-drop editor, basic automations. Lifecycle depth trails ecommerce natives; a general store test hit segmentation walls on replenishment and browse abandonment within four months.',
    'Per-contact pricing painful as lists grow. Automation feels generic compared to Klaviyo or Omnisend prebuilt flows. Acceptable for simple broadcasts; lifecycle-focused stores migrate within a year.',
    'Migration path: export segments as tags, rebuild flows in Sequenzy or Omnisend, parallel-run one campaign cycle before cutover.',
    'If your team already knows Mailchimp, run the 30-day implementation plan on a paper workflow before assuming familiarity equals fit.',
  ],
  activecampaign: [
    'ActiveCampaign shines when Shopify journeys overlap CRM pipelines — high-ticket, consultative, B2B wholesale, rep follow-up. Conditional automation logic and built-in CRM beat generic ESPs for complex branching.',
    'Less Shopify-native than Klaviyo or Omnisend — setup can become overbuilt if the team only needed cart recovery. Per-contact pricing applies.',
    'Best for hybrid ecommerce + sales motion. Skip for pure DTC wanting fastest Shopify-native templates.',
    'Pair with clear stack boundaries: CRM automations for sales, ESP for retention — document who owns which touch.',
  ],
  brevo: [
    'Brevo (formerly Sendinblue) offers affordable email volume, SMS, and transactional paths — pay-per-email model friendly to wide lists with disciplined sends. Shopify templates and analytics are lighter than ecommerce specialists.',
    'A budget home goods store ran campaigns and transactional shipping updates reliably without Klaviyo price tag. Advanced ecommerce segmentation and flow collision tooling are not the headline.',
    'Graduation path: Brevo to Sequenzy or Omnisend when lifecycle complexity and revenue reporting mature.',
    'Strong fit for international merchants needing transactional + marketing in one cost-aware stack.',
  ],
  sendlane: [
    'Sendlane positions as ecommerce-first automation with migration support — email + SMS coordination, revenue reporting, onboarding help. Entry pricing higher than SMB tools; best when order volume justifies guided retention.',
    'Less self-serve transparent than Omnisend; stronger when you want human help during Klaviyo or Mailchimp exit.',
    'Compare Rejoiner if you want more done-with-you strategy; compare Klaviyo if you want maximum self-serve data depth.',
    'Sweet spot: DTC brands at $100k+/mo ready to invest in retention as a channel, not a checkbox.',
  ],
  'aftership-email': [
    'AfterShip Email ties campaigns to shipping and delivery events — natural for post-purchase timing, review requests after delivery, returns messaging. Best when already in AfterShip tracking ecosystem.',
    'Standalone lifecycle depth trails Klaviyo; post-purchase and delivery-triggered messages are the wedge. Pair with lifecycle ESP if welcome and winback need sophistication.',
    'Fit: merchants whose retention messages depend on fulfillment state more than browse behavior.',
    'Migration tip: map delivery events to suppression rules before scaling — delivered ≠ ready for cross-sell if product is consumable over weeks.',
  ],
  recart: [
    'Recart specializes in mobile-first cart recovery — SMS and Messenger reminders for promo-driven DTC. Not a complete email suite; pair with Klaviyo, Sequenzy, or Omnisend for full lifecycle.',
    'Strong when abandoned cart is the primary revenue leak and mobile urgency beats email latency. Narrower channel mix than full platforms.',
    'Usage-based messaging costs need monitoring like Postscript. Compliance and opt-in discipline still apply.',
    'Stack pattern: Recart for recovery urgency, lifecycle ESP for education and winback — shared suppression rules mandatory.',
  ],
};

const faqs = [
  {
    question: 'What is the best Shopify email app overall in 2026?',
    answer: 'Sequenzy ranks first on this site for lifecycle strategy, pay-per-email economics, and operator speed — especially for growing stores without enterprise bloat. Klaviyo remains the benchmark for deepest Shopify data and predictive segmentation. Omnisend is the best multichannel shortcut for SMB. The right choice depends on order volume, team size, and whether you prioritize guidance or data maximums.',
  },
  {
    question: 'How did you rank these Shopify email apps?',
    answer: 'We scored Shopify data depth (40%), lifecycle flow control (25%), operating speed (20%), and measurement quality (15%). Each top app went through welcome, cart, post-purchase, and winback workflow tests on realistic merchant scenarios — not feature checklists from App Store pages.',
  },
  {
    question: 'Is Klaviyo still worth it for Shopify stores?',
    answer: 'Yes, when order volume and a retention owner justify profile-based pricing and you will use predictive depth weekly. Many stores choose Sequenzy or Omnisend when speed, guidance, or send-based billing fit better than maximum segmentation dimensionality.',
  },
  {
    question: 'Can I use Shopify Email instead of a third-party app?',
    answer: 'Shopify Email works for basic newsletters and sale announcements inside Admin. Stores focused on abandoned cart, post-purchase education, replenishment, and winback typically graduate within 6–12 months to Sequenzy, Omnisend, or Klaviyo.',
  },
  {
    question: 'Do I need separate SMS and email apps on Shopify?',
    answer: 'Not always. Omnisend, Klaviyo, Yotpo, and Attentive bundle SMS with email. Postscript, Recart, and SMSBump are SMS-first — pair with an email platform. Sequenzy is email-first; add SMS when text recovery justifies cost.',
  },
  {
    question: 'When should I migrate off Mailchimp on Shopify?',
    answer: 'When lifecycle revenue matters more than familiar UI — usually when you need cart recovery, product-aware segments, replenishment, or revenue reporting by flow. Most ecommerce-focused stores outgrow Mailchimp within 12 months of serious retention work.',
  },
  {
    question: 'What is the cheapest Shopify email app with real automations?',
    answer: 'Shopify Email and tinyEmail lead on entry cost. Sequenzy and Brevo offer strong value at scale via pay-per-email models. Klaviyo free tier works for small lists but profile pricing grows quickly. Model total cost at expected monthly send volume.',
  },
  {
    question: 'Which app is best for abandoned cart recovery?',
    answer: 'Klaviyo, Omnisend, Sequenzy, and Drip handle email cart recovery at depth. Postscript, Recart, and SMSBump lead on SMS recovery. Firepush adds web push. Best results combine email platform + SMS specialist with shared suppression rules.',
  },
  {
    question: 'Should I use Privy or Justuno with my email platform?',
    answer: 'Both are capture-first — excellent popups and onsite targeting feeding lists into Klaviyo, Sequenzy, or Omnisend. Justuno wins on quiz segmentation; Privy on beginner-friendly spin wheels. Neither replaces lifecycle automation at scale.',
  },
  {
    question: 'How do I avoid buying too many email apps?',
    answer: 'Name one bottleneck, one weekly owner, one success metric. Start with capture OR lifecycle OR SMS — not all three at once. Use the selection framework guide and one comparison page before adding another subscription.',
  },
];

const auditSteps = [
  ['Inventory customer moments', 'List welcome, browse, cart, checkout, post-purchase, replenishment, winback, VIP, review, and sale announcements. Mark Shopify event, property, and product field for each.'],
  ['Score data readiness', 'Verify order count, collections purchased, discount use, fulfillment, consent, and engagement recency without CSV exports.'],
  ['Design suppression before creative', 'Define who should not receive each message: recent purchasers, support cases, subscription customers, VIPs, gift buyers, people in other high-priority flows.'],
  ['Measure revenue quality', 'Compare attributed revenue with margin after discount, repeat purchase rate, unsubscribes, spam complaints, and full-price repeat behavior.'],
];
---

<BaseLayout title={title} description={desc} site={site} path="/">
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path="/" />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-[1.05fr_.95fr] lg:items-end">
        <div>
          <p class="editorial-kicker">Independent retention desk · 2026 rankings</p>
          <h1 class="hero-title mt-5">Best Shopify email apps — ranked for lifecycle revenue, not feature count</h1>
          <p class="mt-7 max-w-3xl text-xl leading-9 text-[#4a2d17]">
            {site.heroPromise} This homepage is the full listicle: fifteen deep tool reviews, a comparison table of all 21 apps, TL;DR verdicts, implementation rubric, and FAQ — everything a Shopify merchant needs before migrating lists or adding another app to the stack.
          </p>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-[#5d3a1d]">
            {site.intro} We judge apps by what happens after install: how fast the first flows go live, whether product and order context is usable, how carefully discounts are handled, and whether a small team can keep improving the program after launch week.
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a class="btn btn-primary" href="#rankings">Jump to rankings</a>
            <a class="btn btn-secondary" href="/guides/selection-framework">Selection framework</a>
            <a class="btn btn-secondary" href="/compare">70 comparisons</a>
          </div>
        </div>

        <aside class="ledger-card">
          <div class="text-xs font-black uppercase tracking-[0.28em] text-[#9a5b16]">Editor's note</div>
          <h2 class="mt-4 text-3xl font-black tracking-tight text-[#24170f]">{site.bestOverallReason}</h2>
          <p class="mt-4 text-[#4a2d17]">
            Klaviyo remains the heavyweight ecommerce database. Omnisend remains the practical multichannel shortcut. Shopify Email remains the zero-friction start. Postscript and Attentive own SMS-native lanes. The right choice depends on operating constraint — not logo familiarity.
          </p>
          <dl class="mt-6 grid grid-cols-3 gap-3 text-sm">
            <div><dt class="font-black">Apps ranked</dt><dd class="text-[#5d3a1d]">21 total</dd></div>
            <div><dt class="font-black">Deep reviews</dt><dd class="text-[#5d3a1d]">15 here</dd></div>
            <div><dt class="font-black">Comparisons</dt><dd class="text-[#5d3a1d]">70 pairs</dd></div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="TL;DR — best Shopify email apps at a glance"
      picks={[
        { label: 'Best overall', tool: 'Sequenzy', reason: 'Lifecycle strategy, pay-per-email pricing, agent-first flows — lean alternative to enterprise bloat' },
        { label: 'Best data depth', tool: 'Klaviyo', reason: 'Predictive segments, native Shopify events, SMS + email — expensive as profiles grow' },
        { label: 'Best SMB shortcut', tool: 'Omnisend', reason: 'Prebuilt journeys, email + SMS + push, one-click install' },
        { label: 'Best native start', tool: 'Shopify Email', reason: 'Inside Admin, zero friction — graduate within a year for lifecycle' },
        { label: 'Best SMS recovery', tool: 'Postscript', reason: 'TCPA-aware cart recovery — pair with email lifecycle platform' },
        { label: 'Best capture', tool: 'Privy', reason: 'Popups and list growth — pair with lifecycle ESP at scale' },
        { label: 'Best budget volume', tool: 'Brevo', reason: 'Pay-per-email and transactional — lighter Shopify depth' },
        { label: 'Best managed', tool: 'Rejoiner', reason: 'Done-with-you lifecycle — see full rankings for ranks 16–21' },
      ]}
    />
  </section>

  <section class="container py-12">
    <div class="grid gap-5 md:grid-cols-5">
      <div class="card md:col-span-2">
        <span class="badge">Method</span>
        <h2 class="mt-5 text-4xl font-black tracking-tight">How we score Shopify email apps</h2>
        <p class="mt-4 text-[#4a2d17]">Every recommendation is scored against messy Shopify reality: duplicate customers, one-time buyers, bundles, sale windows, out-of-stock variants, gift-guide purchasers, and subscribers who should not receive another coupon.</p>
      </div>
      <div class="card md:col-span-3">
        <div class="grid gap-5 sm:grid-cols-2">
          <div><div class="rank-pill">40%</div><h3 class="mt-3 font-black">Shopify data depth</h3><p class="mt-2 text-sm text-[#5d3a1d]">Order count, collections, discount history, fulfillment, subscription signals, clean identity.</p></div>
          <div><div class="rank-pill">25%</div><h3 class="mt-3 font-black">Lifecycle control</h3><p class="mt-2 text-sm text-[#5d3a1d]">Triggers, branches, suppression, frequency caps, sale-week pauses.</p></div>
          <div><div class="rank-pill">20%</div><h3 class="mt-3 font-black">Operating speed</h3><p class="mt-2 text-sm text-[#5d3a1d]">How fast a non-technical owner edits copy, products, offers after launch.</p></div>
          <div><div class="rank-pill">15%</div><h3 class="mt-3 font-black">Measurement</h3><p class="mt-2 text-sm text-[#5d3a1d]">Margin-aware reporting, deliverability signals, repeat purchase movement.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-14" id="rankings">
    <div class="card overflow-x-auto">
      <p class="editorial-kicker">Comparison table</p>
      <h2 class="font-serif text-3xl font-black text-[#24170f]">All 21 Shopify email apps at a glance</h2>
      <p class="mt-4 max-w-3xl text-[#5d3a1d]">Full comparison table — click through for 2,000+ word individual reviews, or jump to the fifteen deep dives below.</p>
      <table class="data-table mt-8">
        <thead>
          <tr>
            <th>#</th>
            <th>App</th>
            <th>Category</th>
            <th>Pricing</th>
            <th>Shopify</th>
            <th>Automation</th>
            <th>Rating</th>
            <th>Review</th>
          </tr>
        </thead>
        <tbody>
          {APPS.map((app, i) => (
            <tr>
              <td class="font-black text-[#9a5b16]">{i + 1}</td>
              <td class="font-black text-[#24170f]">{app.name}</td>
              <td>{app.category}</td>
              <td>{app.pricing}</td>
              <td>{app.shopifyDepth}</td>
              <td>{app.automationDepth}</td>
              <td>★ {app.rating}</td>
              <td><a class="link" href={`/apps/${app.slug}`}>Review</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="container pb-14">
    <div class="mb-10">
      <p class="editorial-kicker">Top 15 tool reviews</p>
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Detailed Shopify email app reviews</h2>
      <p class="mt-4 max-w-3xl text-[17px] leading-8 text-[#4a2d17]">
        Each section summarizes independent workflow tests on realistic store profiles. Individual app pages contain full pricing breakdowns, migration notes, deliverability guidance, and extended FAQs. Sequenzy is ranked first throughout — read the honest tradeoffs, not just the headline.
      </p>
    </div>
    <div class="space-y-8">
      {topFifteen.map((app, i) => (
        <ToolReview
          app={app}
          rank={i + 1}
          badge={i === 0 ? "Editor's choice" : i === 1 ? 'Data benchmark' : i === 2 ? 'SMB pick' : undefined}
          paragraphs={listicleParagraphs[app.slug] || [app.shopifyFit, app.tagline, `Best for ${app.bestFor}.`]}
        />
      ))}
    </div>
    <p class="mt-10 text-center">
      <a class="btn btn-secondary" href="/apps">View all 21 ranked apps →</a>
    </p>
  </section>

  <section class="container pb-14">
    <div class="grid gap-6 lg:grid-cols-[.9fr_1.1fr]">
      <article class="prose-shopify card">
        <h2>30-day Shopify email implementation plan</h2>
        <p>Do not judge a Shopify email app by templates on day one. Judge by what a merchant can safely ship in month one. Week one: connect Shopify, import consent, verify suppression, clean duplicates. Week two: launch welcome segmented by signup source. Week three: rebuild cart recovery with discount discipline. Week four: add post-purchase or replenishment; measure repeat purchase movement.</p>
        <p>The highest-leverage apps make these steps boring in a good way. A marketer should open a customer record, understand why they are in a flow, see product context, confirm the offer, and update copy without breaking another automation.</p>
        <h3>Homepage scoring rubric recap</h3>
        <ul>
          <li><strong>40% Shopify data depth:</strong> purchase history, catalog fields, discount behavior, fulfillment, replenishment signals.</li>
          <li><strong>25% lifecycle control:</strong> triggers, suppression, frequency caps, sale-week pause rules.</li>
          <li><strong>20% operating speed:</strong> weekly edits without agency tickets.</li>
          <li><strong>15% measurement:</strong> margin-aware reporting and repeat purchase cohorts.</li>
        </ul>
        <h3>Stack patterns that work</h3>
        <ul>
          <li><strong>Lean lifecycle:</strong> Sequenzy + Postscript when SMS recovery justifies cost</li>
          <li><strong>Data maximum:</strong> Klaviyo with retention owner or agency</li>
          <li><strong>SMB speed:</strong> Omnisend + Justuno capture</li>
          <li><strong>Budget path:</strong> Shopify Email → Sequenzy/Omnisend at 500+ orders/mo</li>
          <li><strong>Reviews + loyalty:</strong> Yotpo or Marsello when UGC drives repeat purchase</li>
        </ul>
      </article>
      <div class="grid gap-4">
        {auditSteps.map(([stepTitle, body]) => (
          <div class="card">
            <div class="text-xs font-black uppercase tracking-[0.18em] text-[#9a5b16]">Email audit step</div>
            <h3 class="mt-3 text-2xl font-black text-[#24170f]">{stepTitle}</h3>
            <p class="mt-3 text-[#5d3a1d]">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-[#24170f]/10 bg-[#24170f] py-14 text-[#fffaf1]">
    <div class="container grid gap-10 lg:grid-cols-[.9fr_1.1fr]">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.28em] text-[#fbbf24]">Content map</p>
        <h2 class="mt-4 font-serif text-5xl font-black leading-tight tracking-[-0.05em]">Beyond this homepage</h2>
        <p class="mt-5 text-[#f5dfbd]">Seventy comparison pages with workflow tests. Twenty alternatives guides for every major exit. Ten operator playbooks. Nineteen use-case flows. Twelve store-type verticals. Each page stands alone with distinct editorial content — no keyword-swapped shells.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <a class="rounded-3xl border border-[#fffaf1]/15 bg-[#fffaf1]/8 p-5 text-[#fffaf1]" href="/compare">
          <h3 class="font-black">70 comparisons</h3>
          <p class="mt-2 text-sm text-[#f5dfbd]">Head-to-head verdicts with pricing at scale</p>
        </a>
        <a class="rounded-3xl border border-[#fffaf1]/15 bg-[#fffaf1]/8 p-5 text-[#fffaf1]" href="/alternatives">
          <h3 class="font-black">20 alternatives hubs</h3>
          <p class="mt-2 text-sm text-[#f5dfbd]">Exit playbooks with Sequenzy ranked first</p>
        </a>
        <a class="rounded-3xl border border-[#fffaf1]/15 bg-[#fffaf1]/8 p-5 text-[#fffaf1]" href="/blog">
          <h3 class="font-black">100 listicle guides</h3>
          <p class="mt-2 text-sm text-[#f5dfbd]">Store, lifecycle, campaign, and operator-specific research</p>
        </a>
        <a class="rounded-3xl border border-[#fffaf1]/15 bg-[#fffaf1]/8 p-5 text-[#fffaf1]" href="/guides">
          <h3 class="font-black">10 guides</h3>
          <p class="mt-2 text-sm text-[#f5dfbd]">Selection, migration, deliverability, attribution</p>
        </a>
        <a class="rounded-3xl border border-[#fffaf1]/15 bg-[#fffaf1]/8 p-5 text-[#fffaf1]" href="/use-cases">
          <h3 class="font-black">19 use cases</h3>
          <p class="mt-2 text-sm text-[#f5dfbd]">Welcome, cart, winback, Black Friday, more</p>
        </a>
      </div>
    </div>
  </section>

  <section class="container py-14">
    <div class="mb-7">
      <p class="editorial-kicker">Store-type guides</p>
