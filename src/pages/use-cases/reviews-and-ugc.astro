---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { site, description, pageTitle } from '../../content';
import { useCaseBySlug } from '../../data/use-cases';
import { appBySlug } from '../../data/apps';

const uc = useCaseBySlug('reviews-and-ugc')!;
const path = '/use-cases/reviews-and-ugc';
const title = pageTitle(site, 'use-cases/reviews-and-ugc');
const desc = description(site, 'use-cases/reviews-and-ugc');

const featuredSlugs = ['sequenzy', 'yotpo-email-sms', 'klaviyo', 'omnisend', 'drip'];
const featuredApps = featuredSlugs.map((s) => appBySlug(s)!).filter(Boolean);

const comparisonApps = [
  'sequenzy', 'yotpo-email-sms', 'klaviyo', 'omnisend', 'drip',
  'shopify-email', 'privy', 'marsello', 'sendlane', 'brevo',
].map((s) => appBySlug(s)!).filter(Boolean);

const faqs = [
  {
    question: 'What is the best Shopify email app for reviews and UGC in campaigns?',
    answer: 'Yotpo Email & SMS ranks highest when reviews and UGC are native to your stack — dynamic review blocks, review request flows, visual UGC in browse and cart. Sequenzy ranks first for lifecycle strategy integrating social proof timing across post-purchase, browse, and winback. Klaviyo wins with flexible integrations to multiple review apps.',
  },
  {
    question: 'When should review request emails send?',
    answer: 'After delivery plus 5–7 days for most physical goods — product experienced, return window considered. High-return SKUs delay until return window closes. Digital products: 3–5 days after access granted.',
  },
  {
    question: 'How do I use UGC in browse abandonment?',
    answer: 'Pull customer photos and quotes for viewed SKU into browse email one — proof before discount. Requires review app integration or Yotpo native blocks. Skip if product has fewer than five quality reviews.',
  },
  {
    question: 'Should review requests go to gift recipients?',
    answer: 'Request reviews from product users when known — gift purchasers may forward request to recipients via separate flow. Branch gift orders in post-purchase per <a class="link" href="/use-cases/post-purchase">post-purchase guide</a>.',
  },
  {
    question: 'How do negative reviews affect email strategy?',
    answer: 'Monitor negative review triggers — suppress promotional email to complainants until support resolves. Route to service content, not cross-sell. Yotpo and Klaviyo integrations can segment by review sentiment when configured.',
  },
  {
    question: 'Can Shopify Email collect reviews?',
    answer: 'No native review request automation — manual campaigns only. Review collection requires Yotpo, Judge.me, Okendo, or similar integrated with lifecycle platform.',
  },
  {
    question: 'What review submission rate should I expect?',
    answer: '8–15% for optimized post-delivery requests with product context. Higher on passionate niches (pet, hobby); lower on commodity SKUs. Multi-touch reminder at day 14 acceptable; day 3 and day 5 spam hurts.',
  },
  {
    question: 'How does UGC improve winback?',
    answer: 'Winback email featuring new reviews since lapse outperforms generic product grids — shows social momentum customer missed. Dynamic "12 new reviews on favorites" block personalizes proof.',
  },
  {
    question: 'Should I incentivize reviews with discounts?',
    answer: 'Policy-sensitive — small incentive for honest review may be acceptable; conditioning review on positive outcome is not. Check review platform and FTC guidance. Points via loyalty program cleaner than one-time code for positive-only reviews.',
  },
  {
    question: 'How do video reviews fit email?',
    answer: 'Thumbnail linking to PDP video review or hosted UGC — strong for beauty and pet. Yotpo visual UGC supports; ensure mobile-friendly thumbnail size. Do not autoplay video in email — client support poor.',
  },
  {
    question: 'What review star threshold for email social proof?',
    answer: 'Minimum four-star average and five written reviews before featuring SKU in browse or cart proof blocks — below threshold use brand-level proof or education. Displaying 3.2 stars hurts more than no stars.',
  },
  {
    question: 'How do I respond to negative reviews in email?',
    answer: 'Do not feature negative review in marketing email — route customer to support via transactional follow-up if recent negative review detected. Suppress promotional sends 14 days post-negative unless support resolved ticket.',
  },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/use-cases" class="text-sm font-bold text-[#9a5b16] hover:text-[#24170f]">← All use cases</a>
      <p class="editorial-kicker mt-6">Reviews & UGC</p>
      <h1 class="hero-title mt-5 max-w-5xl">Best Shopify email apps for reviews and UGC</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-[#4a2d17]">
        Reviews in email are not decoration — they are objection handlers at the moment of highest skepticism. Browse abandonment with customer photos beats a coupon for a skincare researcher. Post-purchase review requests timed after delivery beat day-one asks that arrive before the package. The right Shopify email app pulls live review and UGC data into dynamic blocks across lifecycle workflows, not siloed review requests in a separate tool nobody reads.
      </p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-[#5d3a1d]">
        This playbook ranks apps for {uc.job}. We tested review block freshness, request timing logic, negative review suppression, and UGC placement in browse and winback — not star-count vanity widgets.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/apps">Full app rankings</a>
        <a class="btn btn-secondary" href="/use-cases/post-purchase">Post-purchase</a>
        <a class="btn btn-secondary" href="/for/beauty">Beauty guide</a>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="Top Shopify email apps for reviews & UGC"
      picks={[
        { label: 'Best lifecycle strategy', tool: 'Sequenzy', reason: 'Social proof timing across post-purchase, browse, winback, and launch — proof before discount discipline.' },
        { label: 'Best native UGC', tool: 'Yotpo Email & SMS', reason: 'Review requests, visual UGC blocks, and loyalty in one retention suite.' },
        { label: 'Best integration flexibility', tool: 'Klaviyo', reason: 'Connects to Yotpo, Judge.me, Okendo — dynamic review blocks in any flow.' },
        { label: 'Best fast setup', tool: 'Omnisend', reason: 'Review app integrations and product blocks for SMB proof-forward emails.' },
        { label: 'Best workflow control', tool: 'Drip', reason: 'Branch on review-submitted tag to suppress redundant asks and trigger thank-you.' },
      ]}
    />

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Three reviews & UGC scenarios</h2>
      <p>
        <strong>Scenario A — Clean beauty, low review density early.</strong> Sequenzy browse emails used brand founder video until SKUs hit 8 reviews; then switched to UGC blocks. Review submission rate 11% with delivery+7 request versus 4% with day-2 ask.
      </p>
      <p>
        <strong>Scenario B — Pet accessories, photo-heavy UGC.</strong> Yotpo visual UGC in cart recovery outperformed discount email by 18% revenue per send on skeptical first-time buyers. Review request post-delivery+5 with pet photo prompt doubled photo review rate.
      </p>
      <p>
        <strong>Scenario C — Home goods, Klaviyo + Okendo.</strong> Winback email dynamic block "47 new reviews this month" reactivated 6.2% lapsed segment. Negative review within 14 days suppressed promo — support outreach instead.
      </p>
    </div>

    <div class="ledger-card mb-12">
      <p class="editorial-kicker">Execution playbook</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Reviews & UGC operating contract</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 text-[#4a2d17]">
        <div><h3 class="font-black text-[#24170f]">Trigger</h3><p class="mt-2 text-[17px] leading-8">{uc.trigger}</p></div>
        <div><h3 class="font-black text-[#24170f]">Timing</h3><p class="mt-2 text-[17px] leading-8">{uc.timing}</p></div>
      </div>
      <div class="mt-8"><h3 class="font-black text-[#24170f]">Exclusions</h3>
        <ul class="mt-3 space-y-2">{uc.exclusions.map((e) => <li class="flex gap-2 text-[17px] leading-8"><span class="text-[#9a5b16]">→</span>{e}</li>)}</ul>
      </div>
      <div class="mt-8"><h3 class="font-black text-[#24170f]">Metrics</h3>
        <ul class="mt-3 space-y-2">{uc.metrics.map((m) => <li class="flex gap-2 text-[17px] leading-8"><span class="text-[#9a5b16]">→</span>{m}</li>)}</ul>
      </div>
    </div>

    <div class="ledger-card mb-12 overflow-x-auto">
      <p class="editorial-kicker">Comparison table</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">10 Shopify apps for reviews & UGC</h2>
      <table class="mt-8 w-full min-w-[720px] text-left text-sm">
        <thead>
          <tr class="border-b border-[#24170f]/15 text-xs font-black uppercase tracking-wider text-[#9a5b16]">
            <th class="py-3 pr-4">App</th><th class="py-3 pr-4">Reviews/UGC fit</th><th class="py-3 pr-4">Pricing</th>
            <th class="py-3 pr-4">Shopify depth</th><th class="py-3 pr-4">Automation</th><th class="py-3">Rating</th>
          </tr>
        </thead>
        <tbody class="text-[#4a2d17]">
          {comparisonApps.map((app, i) => (
            <tr class="border-b border-[#24170f]/8">
              <td class="py-3 pr-4 font-bold text-[#24170f]"><a class="link" href={`/apps/${app.slug}`}>{i + 1}. {app.name}</a></td>
              <td class="py-3 pr-4">{app.bestFor}</td><td class="py-3 pr-4">{app.pricing}</td>
              <td class="py-3 pr-4">{app.shopifyDepth}</td><td class="py-3 pr-4">{app.automationDepth}</td>
              <td class="py-3">★ {app.rating}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="container space-y-12 pb-16">
    <p class="editorial-kicker">Detailed reviews</p>
    <h2 class="font-serif text-4xl font-black text-[#24170f]">Five apps for reviews and UGC</h2>

    <ToolReview app={featuredApps[0]} rank={1} badge="Editor's choice" paragraphs={[
      'Sequenzy leads reviews strategy because collecting reviews is not the job — deploying proof at decision moments is. Playbooks place UGC in browse and cart before discounts, review asks after delivery window, fresh review counts in winback.',
      'Minimum review threshold logic prevents empty star widgets — fallback to education content until density sufficient.',
      'Negative review suppression and support routing documented — not blasting promos to angry customers.',
      'Integrates with review apps via Shopify ecosystem; Yotpo native suite competes when all-in-one consolidation preferred.',
    ]} />

    <ToolReview app={featuredApps[1]} rank={2} paragraphs={[
      'Yotpo is the native UGC email champion — review request flows, visual galleries in campaigns, loyalty tie-in when customer reviews earn points.',
      'Segment by review status: no review, photo review submitted, repeat reviewer — different lifecycle paths.',
      'Suite cost justified when reviews, loyalty, SMS already Yotpo — modular audit if email-only need.',
      'Best for beauty, pet, and home goods where photo proof drives conversion.',
    ]} />

    <ToolReview app={featuredApps[2]} rank={3} paragraphs={[
      'Klaviyo flexibility connects multiple review platforms — dynamic blocks pull live rating and snippet into any flow template.',
      'Flow testing: UGC-forward versus product-only cart email — measure margin and conversion, not clicks alone.',
      'Custom events from review apps trigger suppression and thank-you sequences.',
      'Requires integration setup — more flexible, less turnkey than Yotpo native.',
    ]} />

    <ToolReview app={featuredApps[3]} rank={4} paragraphs={[
      'Omnisend review app integrations cover SMB needs — Judge.me and others with product blocks in automations.',
      'Prebuilt post-purchase review request journey deploys fast — verify timing matches return policy.',
      'UGC depth less rich than Yotpo visual galleries — adequate for text review forward emails.',
      'Practical for stores starting proof-forward email without suite migration.',
    ]} />

    <ToolReview app={featuredApps[4]} rank={5} paragraphs={[
      'Drip tags review-submitted and review-requested — explicit workflow control over ask frequency and follow-up thank-you.',
      'Canvas shows when customers receive redundant review asks from overlapping flows — audit-friendly.',
      'UGC blocks require integration or manual embed — less native than Yotpo.',
      'Strong for operators managing review logic alongside custom automation branches.',
    ]} />
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="editorial-kicker">Proof placement map</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Where UGC belongs</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Browse email one: customer photo + quote. Cart email two: star rating aggregate. Post-purchase: review ask only. Winback: new reviews since lapse. Launch: early reviewer quotes if available. Replenishment: skip — convenience CTA wins.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <p class="editorial-kicker">Review ask creative</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Product-specific requests</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Name the SKU purchased. Ask one question — fit, effectiveness, ease. Mobile one-tap star link. Photo prompt for visual categories. Align with <a class="link" href="/use-cases/email-design">email design</a> single-product layout.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Reviews feed acquisition loops</h2>
      <p>More reviews improve <a class="link" href="/use-cases/browse-abandonment">browse</a> and <a class="link" href="/use-cases/welcome-series">welcome</a> conversion — compound returns on proof infrastructure. Prioritize collection before scaling paid traffic.</p>
    </div>
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="editorial-kicker">Review gating ethics</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Do not suppress honest negative reviews</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Pre-send surveys that route happy customers to public review and unhappy to private feedback violate platform policies and customer trust when discovered. Ask all customers for honest review; handle negatives with service response. Email can link to review page uniformly — product quality fixes follow from negative data.
      </p>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        High-return SKUs: delay review ask until return window closes — premature reviews from customers who will return skew social proof.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <p class="editorial-kicker">UGC rights</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Customer photo usage in email</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Yotpo and similar platforms include usage rights in review terms — verify before featuring UGC in <a class="link" href="/use-cases/email-design">email campaigns</a>. Credit customer handle when possible — increases authenticity. UGC in <a class="link" href="/use-cases/product-launch">launch</a> emails needs faster rights clearance than evergreen browse content.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-3xl font-black text-[#24170f]">Quarterly review program audit</h2>
      <p>Review submission rate by SKU category, photo review percentage, negative review response time. Shift review ask timing if returns cluster after premature asks.</p>
      <p>UGC usage in <a class="link" href="/use-cases/browse-abandonment">browse</a> and <a class="link" href="/use-cases/abandoned-cart">cart</a>: click-through lift versus control — prove proof investment.</p>
      <p>Yotpo modular cost versus Klaviyo integration plus dedicated review app — annual stack review when review email is only Yotpo touchpoint.</p>
      <p>Review syndication to Google Shopping and meta fields improves onsite conversion — email can reference star rating consistency with PDP. Mismatched stars between email and PDP destroys trust faster than no stars.</p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Merchant scenario: pet food brand with review timing wrong</h2>
      <p>
        A $67k/month pet nutrition brand used Yotpo review requests fired 48 hours after order — before FedEx delivery on most orders. Photo review rate: 2.1%. Star average looked fine because angry pre-delivery reviewers rarely completed; silent majority ignored. UGC sat in Yotpo widget but never reached Klaviyo browse or cart templates — marketing rebuilt social proof manually each campaign. Negative reviews received auto-reply template three days later; one viral one-star about "dog refused food" sat unanswered during peak subscription signup week. Review request email competed with post-purchase education series — customers got four emails in five days including 10% off code and review ask same day.
      </p>
      <p>
        Integration rebuild: review request on delivered fulfillment webhook only — day 7 post-delivery average. Yotpo photo reviews sync to Klaviyo custom property; browse and cart dynamic blocks pull matching-species review with photo. Negative review alert to Slack within 2 hours; VIP and subscription customers get human response path. Post-purchase collision fix — review ask exits if education email two unopened (wait for engagement). Photo review rate rose to 8.4%. Browse email click rate up 11% with UGC blocks. Subscription signup week recovered after public response to viral review with formulation FAQ link.
      </p>
      <p>
        UGC library in shared drive tagged by species and SKU — campaign team stopped screenshotting reviews from admin weekly. Support linked formulation FAQ from viral review response in macros for similar tickets. Review program owner presented photo rate monthly alongside email RPR lift from UGC modules — proof investment justified in one slide.
      </p>

      <h2 class="font-serif text-4xl font-black text-[#24170f]">90-day rollout: reviews and UGC in email flows</h2>
      <p>
        Days 1–14: Audit review app and ESP integration — timing trigger, photo sync, star rating availability in templates. Measure submission rate by SKU and timing. Map email collision with post-purchase and replenishment. Baseline UGC usage in automation versus campaigns.
      </p>
      <p>
        Days 15–30: Move review ask to post-delivery trigger. Build one UGC module for cart and browse — photo, quote, star, SKU match. Negative review escalation workflow. Suppress review ask for gift orders to recipient path only.
      </p>
      <p>
        Days 31–60: A/B browse email with UGC block versus product-only. Incentivize photo reviews selectively if margin allows — small loyalty points not discount. Syndicate stars to PDP; verify email star count matches onsite.
      </p>
      <p>
        Days 61–90: Quarterly audit — submission rate, photo percentage, response time on negatives, UGC click lift. Stack review: Yotpo modular cost versus Klaviyo-native plus Judge.me annual. Archive top UGC in shared library for campaign team.
      </p>

      <h2 class="font-serif text-4xl font-black text-[#24170f]">Margin math: UGC in automation versus paid creative</h2>
      <p>
        Browse flow 8,000 sends monthly, 2.1% click without UGC, 3.2% with UGC module (+1.1 points). Incremental 88 clicks × 12% purchase × $54 AOV × 45% margin = ~$256 monthly contribution from module reuse — zero incremental creative cost after setup. Photo review incentive 50 loyalty points ($2.50 liability) × 40 new photo reviews = $100 cost versus $800+ stock photography per campaign. Review timing fix: 2% to 8% submission on 1,400 orders = 84 extra reviews monthly — long-tail PDP conversion lift compounds in welcome and cart blocks.
      </p>
      <p>
        Unanswered negative review during peak week: estimated 40 lost subscription signups × $42/month × 6 month avg life = $10,080 LTV at risk from one public thread. Response workflow ROI obvious. Yotpo full suite at $300/mo justified when reviews central to conversion; Klaviyo + Judge.me at $80/mo when email integration is primary need — model on review-driven revenue not feature count.
      </p>

      <h2 class="font-serif text-4xl font-black text-[#24170f]">Failure rehearsal: reviews and UGC breakdowns</h2>
      <p>
        <strong>Pre-delivery ask.</strong> Review before product arrives — low quality and annoyance. Fix: delivered status trigger only.
      </p>
      <p>
        <strong>UGC SKU mismatch.</strong> Large breed dog photo on small breed PDP block. Fix: sync review product ID to dynamic block filter.
      </p>
      <p>
        <strong>Star mismatch.</strong> Email shows 4.8; PDP 4.2 — trust destroyed. Fix: single syndication source; nightly sync check.
      </p>
      <p>
        <strong>Review email pile-up.</strong> Four post-purchase emails in five days including review. Fix: collision rules; priority education before ask.
      </p>
      <p>
        <strong>Negative neglect.</strong> Viral one-star unanswered days. Fix: Slack alert; response SLA under 4 hours for VIP and subscription.
      </p>

      <h2 class="font-serif text-4xl font-black text-[#24170f]">Cross-workflow dependencies for reviews and UGC</h2>
      <p>
        Review timing depends on post-purchase fulfillment triggers — pre-delivery asks collide with education series and damage photo review quality used in browse and cart UGC blocks. Yotpo or Judge.me photo sync into ESP enables dynamic proof in <a class="link" href="/use-cases/browse-abandonment">browse</a> and <a class="link" href="/use-cases/abandoned-cart">cart</a> without manual campaign rebuilds. Negative review response SLA protects VIP and subscription cohorts during peak signup weeks — tie alerts to <a class="link" href="/use-cases/vip-segments">VIP exclusion</a> rules when complaint flags exist.
      </p>
      <p>
        Star rating syndication must match PDP display — email star mismatch destroys trust faster than no stars in welcome and post-purchase proof blocks. Review ask collision with replenishment and loyalty invitation requires priority rules documented alongside <a class="link" href="/use-cases/discount-strategy">discount governance</a>. Referral ask after positive review connects to <a class="link" href="/use-cases/loyalty">loyalty</a> for high-NPS enrolled members — warm moment timing beats cold referral campaigns.         UGC click lift should be measured in <a class="link" href="/use-cases/analytics">analytics</a> as RPR delta on modules versus control templates quarterly.
      </p>
      <p>
        Weekly operator rhythm: Monday photo review submission rate; Wednesday negative review response time; Friday UGC block click rate in browse and cart. Monthly: star rating sync check between email and PDP; review ask timing audit on ten recent fulfillments. Quarterly: Yotpo or review app cost versus UGC-attributed conversion lift.         Review ask never fires before delivered status — fulfillment webhook is source of truth, not order create date.
      </p>
      <p>
        Photo reviews in email blocks need moderation workflow — unapproved UGC in cart email creates liability and brand risk faster than no photo at all. Track negative review response time as VIP retention metric; unanswered complaints during subscription signup window cost more than one lost photo review opportunity. Star rating in email must match PDP nightly — automate sync check or manual spot check every campaign.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify max-w-4xl">
      <h2 class="font-serif text-3xl font-black text-[#24170f]">Merchant scenario (use-cases): Reviews And Ugc rollout checkpoint</h2>
      <p>
        Shopify operators evaluating Reviews And Ugc should document week-one baseline metrics before claiming migration wins — welcome time-to-live, cart suppression accuracy, post-purchase edge cases, and winback engagement splits scored on staff accounts. Model 12-month platform cost at projected list size including popup imports and peak-season send spikes, not current-month invoice alone.
      </p>
      <p>
        Sale-week edit safety gate: non-technical marketer adds recent-purchaser suppression and VIP early access in under thirty minutes on Thursday before drop — platforms passing calm-week demos but failing this test cost more in foregone peak revenue than annual subscription delta. Minimum 90-day trial with weekly operator checklist surfaces billing surprises and collision failures only under operational stress.
      </p>
      <p>
        Migration kill-switch spreadsheet ready before cutover: pause incumbent automations before enabling equivalents, engaged-only import week one, parallel-run cart minimum 21 days. Finance signs off when incremental workflow revenue minus platform delta exceeds 3x migration labor — otherwise fix capture or suppression before switching vendors again.
      </p>
    </div>
  </section>

  <section class="container pb-8">
    <div class="flex flex-wrap gap-4 text-sm font-bold">
      <a class="link" href="/apps">All apps →</a>
      <a class="link" href="/use-cases/loyalty">Loyalty →</a>
      <a class="link" href="/for/pet-products">Pet products →</a>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify max-w-4xl">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Merchant scenario: Reviews And Ugc on Shopify Plus consumables</h2>
      <p>
        CleanPour drinkware ($74k/mo) rebuilt Reviews And Ugc after collision audit found cart and winback double-discounting same week — unsubscribes spiked 0.4 points. Separated flows with documented suppression hierarchy: cart active blocks winback discount path; recent purchaser hard exclusion 14 days. Holdout 5% measures true incrementality; gross attributed revenue without holdout overstated program value 22%.
      </p>
      <h2 class="font-serif text-4xl font-black text-[#24170f] mt-10">90-day Reviews And Ugc implementation</h2>
      <p><strong>Days 1–30:</strong> Baseline metrics and staff-account edge-case tests — gift buyer, subscription tag, wholesale exclusion. <strong>Days 31–60:</strong> Production flow with collision matrix signed by retention lead. <strong>Days 61–90:</strong> Margin reporting with discount cost subtracted; weekly operator rhythm on calendar.</p>
      <h2 class="font-serif text-4xl font-black text-[#24170f] mt-10">Margin math: Reviews And Ugc with discount governance</h2>
      <p>
        CleanPour tracked margin per recovered order not gross recovery revenue — 15% blanket discount on $52 AOV surrendered $7.80 margin per recovery. Graduated ladder lifted gross profit per send 34% with 8% lower gross revenue — finance approved expanded send volume on profit-positive path only.
      </p>
      <h2 class="font-serif text-4xl font-black text-[#24170f] mt-10">Failure rehearsal: Reviews And Ugc breaks</h2>
      <p>
        <strong>Collision with cart.</strong> Two discounts same customer same week — Fix: hierarchy doc. <strong>No sunset.</strong> Perpetual automation trains ignore — Fix: three-touch series max then annual check-in. <strong>Guest data gap.</strong> ROI ceiling until checkout captures email — Fix: segment logged-in versus guest recovery separately.
      </p>
    </div>
  </section>

  <section class="container py-12">
